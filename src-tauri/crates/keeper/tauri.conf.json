{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "keeper",
  "version": "0.1.1",
  "identifier": "dev.tgorka.keeper",
  "build": {
    "beforeDevCommand": {
      "script": "bun run dev",
      "cwd": "../../.."
    },
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": {
      "script": "bun run build",
      "cwd": "../../.."
    },
    "frontendDist": "../../../dist"
  },
  "app": {
    "windows": [
      {
        "title": "keeper",
        "width": 1280,
        "height": 800,
        "minWidth": 940,
        "minHeight": 600,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["keeper"]
      }
    },
    "updater": {
      "endpoints": ["https://github.com/tgorka/keeper/releases/latest/download/latest.json"],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDc2QkIzM0YyQjczNUE1RTkKUldUcHBUVzM4ak83ZHFGY3N5S2NSYXdZTUkraE8zVkZOd1E2S3NxNHJTeFRqSWMvZkVoWi9PcVkK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/keeper-rec"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0"
    }
  }
}
