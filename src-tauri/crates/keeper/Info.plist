<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Tauri v2 merges this file into the generated macOS bundle Info.plist (it is
  colocated with tauri.conf.json). Story 16.5 (AD-36): the Screen Recording TCC
  usage string shown when keeper (via its keeper-rec child sidecar) requests
  access. Honest local-only framing — recording adds zero network destinations.
-->
<plist version="1.0">
<dict>
	<key>NSScreenCaptureUsageDescription</key>
	<string>keeper records your screen only when you start a recording. Everything is saved locally on this Mac. Nothing uploads.</string>
	<!--
	  Story 19.3 (FR-69, AD-36): the Microphone TCC usage string shown when keeper
	  (via its keeper-rec child sidecar) requests access — lazily, only when the
	  user enables the mic source. Same honest local-only framing.
	-->
	<key>NSMicrophoneUsageDescription</key>
	<string>keeper records your microphone only when you enable it for a recording. Everything is saved locally on this Mac. Nothing uploads.</string>
</dict>
</plist>
