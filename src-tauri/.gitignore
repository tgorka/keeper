# Generated by Cargo
# will have compiled files and executables
/target/

# Generated by Tauri
# will have schema files for capabilities auto-completion
/gen/schemas
/crates/keeper/gen/schemas

# iOS project (AD-32): commit gen/apple EXCEPT ephemeral build/tooling output.
# project.yml, Info.plist, and the *_iOS/ sources stay tracked; these are
# regenerated by the build / pod install / rust compile and must not be committed.
/crates/keeper/gen/apple/build/
/crates/keeper/gen/apple/Externals/
/crates/keeper/gen/apple/Pods/
/crates/keeper/gen/apple/.xcode/
/crates/keeper/gen/apple/**/xcuserdata/
