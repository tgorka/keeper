# 1Password secret references for local development (no secrets here).
# Usage: op run --env-file=.env.1p -- <command>
# Fill the "keeper dev matrix" item in your Private vault (see docs/credentials.md).
KEEPER_DEV_HOMESERVER="op://Private/keeper dev matrix/homeserver"
KEEPER_DEV_USERNAME="op://Private/keeper dev matrix/username"
KEEPER_DEV_PASSWORD="op://Private/keeper dev matrix/password"
