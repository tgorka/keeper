# Keeper companion stack — environment template. Copy to .env and fill in.
# NO real secrets in this file or in git. Prefer 1Password secret references,
# the same pattern this repo uses for dev credentials (see /.env.1p and
# docs/credentials.md):
#
#   POSTGRES_PASSWORD="op://Private/keeper companion postgres/password"
#   op run --env-file=.env -- docker compose up -d
#
# Plain values in an untracked .env also work if you don't use 1Password.

# Matrix server_name: the domain part of user IDs (@user:SERVER_NAME).
# Cannot be changed after the first start without wiping the database.
SERVER_NAME=matrix.example.com

# URL where clients (keeper) reach the client-server API. No trailing slash.
# With the default compose mapping this is http://<host>:8008 (put a reverse
# proxy with TLS in front for anything non-local).
PUBLIC_URL=http://matrix.example.com:8008

# Existing postgres instance (or the optional bundled service — then use
# POSTGRES_HOST=postgres). host.docker.internal reaches a postgres running on
# the docker host itself.
POSTGRES_HOST=host.docker.internal
POSTGRES_PORT=5432
# Role that owns the synapse/bridge databases (see README for the CREATE
# DATABASE statements — Synapse requires LC_COLLATE=C / LC_CTYPE=C, UTF8).
POSTGRES_USER=synapse
POSTGRES_PASSWORD=change-me   # or an op:// reference, see header

# Shared secret for registering users from the CLI while public registration
# stays disabled (register_new_matrix_user). Generate: openssl rand -hex 32
# Must match registration_shared_secret in data/synapse/homeserver.yaml.
REGISTRATION_SHARED_SECRET=change-me
